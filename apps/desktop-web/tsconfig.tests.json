{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@features/*": ["src/features/*"],
      "@shell/*": ["src/shell/*"]
    },
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false,
    "outDir": ".test-dist",
    "rootDir": "."
  },
  "include": [
    "tests/**/*.ts",
    "src/shell/layout/window-performance-policy.ts",
    "src/features/workspace-hub/station-action-command-sheet-focus.ts",
    "src/features/terminal/station-terminal-input-buffer.ts",
    "src/features/terminal/station-terminal-runtime-state.ts",
    "src/features/terminal/station-terminal-restore-state.ts",
    "src/features/terminal/station-terminal-document-scope.ts",
    "src/features/terminal/terminal-debug-model.ts",
    "src/features/terminal/terminal-stream-decoder.ts",
    "src/features/terminal/terminal-vt-parser.ts",
    "src/features/tool-adapter/channel-message-bubble-model.ts",
    "src/features/tool-adapter/channel-message-layout.ts",
    "src/features/workspace-hub/station-mutation-error.ts"
  ]
}
