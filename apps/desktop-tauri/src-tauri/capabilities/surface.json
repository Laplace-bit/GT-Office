{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "surface",
  "description": "Capability for detached surface windows (surface-*)",
  "windows": ["surface-*"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-close",
    "core:window:allow-set-always-on-top"
  ]
}
