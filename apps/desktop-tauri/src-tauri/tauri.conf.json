{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GT Office",
  "version": "0.1.0",
  "identifier": "dev.gtoffice.app",
  "build": {
    "beforeDevCommand": "cd ../desktop-web && npm run dev",
    "beforeBuildCommand": "cd ../desktop-web && npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../desktop-web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "GT Office",
        "width": 1400,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "decorations": true,
        "transparent": true,
        "shadow": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "acceptFirstMouse": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 24
        }
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/gto-agent-mcp-sidecar"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
